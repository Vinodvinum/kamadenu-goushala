# Admin (Legacy Decap CMS)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Sanity CMS Configuration
# Project ID (already set in code, but can override here)
PUBLIC_SANITY_PROJECT_ID=x568r82t
PUBLIC_SANITY_DATASET=production

# Sanity API Token (read+write - keep this secret, never commit)
# Generate at: https://www.sanity.io/manage/project/x568r82t/api#tokens
SANITY_API_TOKEN=your-sanity-api-token-here

# Sanity Studio URL (after deploying studio)
# PUBLIC_SANITY_STUDIO_URL=https://your-studio-name.sanity.studio
