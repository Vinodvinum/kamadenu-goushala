---
const { product } = Astro.props;
---

<div class="card">

<img src={product.image} alt={product.name}>

<div class="card-body">

<h3 class="card-title">
{product.name}
</h3>

<p style="font-weight:600; color:#e67e22;">
{product.price}
</p>

<p>
{product.description}
</p>

<br>

<div class="cow-card-actions">
<a href={`/products/${product.id}`} class="btn btn-outline">
Know more
</a>

<a
href={`https://wa.me/919448604890?text=${encodeURIComponent(`Namaste Kamadenu Goushala,

I want to order:
Product: ${product.name}
Price: ${product.price}

Please guide me with payment and delivery.`)}`}
target="_blank"
class="btn btn-primary">

WhatsApp

</a>
</div>

</div>

</div>
