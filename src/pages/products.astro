---
import MainLayout from "../layouts/MainLayout.astro";
import { sanityFetch, urlFor } from "../lib/sanityClient";
import { ALL_PRODUCTS_QUERY } from "../lib/queries";
import type { Product } from "../lib/types";

let products: Product[] = [];
let error: string | null = null;

try {
  products = await sanityFetch<Product[]>({ query: ALL_PRODUCTS_QUERY });
} catch (e) {
  error = "Failed to load products. Please try again later.";
  console.error("Products page error:", e);
}

const categories = [...new Set(products.map((p) => p.category).filter(Boolean))];
---

<MainLayout title="Products">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Gau Products</h1>
      <p class="section-subtitle">Pure and natural products from our Goushala — made with love and devotion.</p>

      {error && (
        <div class="error-banner" role="alert">
          <p>{error}</p>
        </div>
      )}

      {!error && products.length === 0 && (
        <div class="empty-state">
          <p>No products available right now. Check back soon!</p>
        </div>
      )}

      {products.length > 0 && (
        <div class="products-grid">
          {products.map((product) => (
            <article class={`product-card ${!product.inStock ? 'product-card--out-of-stock' : ''}`}>
              {product.image ? (
                <img
                  src={urlFor(product.image).width(400).height(400).url()}
                  alt={product.name}
                  class="product-card__image"
                  loading="lazy"
                />
              ) : (
                <div class="product-card__image product-card__image--placeholder"></div>
              )}
              <div class="product-card__body">
                {product.category && <span class="product-card__category">{product.category}</span>}
                <h3 class="product-card__name">{product.name}</h3>
                {product.description && <p class="product-card__desc">{product.description}</p>}
                {product.price && <p class="product-card__price">₹{product.price}</p>}
                <div class="product-card__footer">
                  {!product.inStock && <span class="product-card__oos">Out of Stock</span>}
                  {product.inStock && product.orderLink && (
                    <a href={product.orderLink} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Order Now</a>
                  )}
                  {product.inStock && !product.orderLink && (
                    <a href="/contact" class="btn btn-secondary">Enquire</a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</MainLayout>
