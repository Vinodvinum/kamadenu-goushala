---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

import ProductCard from "../components/ProductCard.astro";

type Product = {
	id: string;
	name: string;
	price: string;
	image: string;
	description: string;
	process: string;
};

const products = [...((await getCollection("products" as any)) as any[])]
	.map((entry) => entry.data)
	.map((entry) => entry as Product)
	.sort((a, b) => a.id.localeCompare(b.id));
---

<MainLayout title="Gou Products">

<section class="section">

<div class="container">

<h1 class="section-title">

Gou Products

</h1>

<p class="section-intro">
Our Gou products are prepared through traditional methods rooted in seva, purity, and natural living.
</p>


<div class="grid">

{
products.map(product => (

<ProductCard product={product} />

))
}

</div>


</div>

</section>

<section class="section">
<div class="container">
<h2 class="section-title">Making Process</h2>

<div class="grid">
{
products.map((product) => (
<article class="card">
<div class="card-body">
<h3 class="card-title">{product.name} - Making Process</h3>
<p>{product.process}</p>
</div>
</article>
))
}
</div>

</div>
</section>

</MainLayout>
