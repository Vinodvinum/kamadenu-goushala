import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About Kamadenu Goushala">

<section class="section">

<div class="container">

<h1 class="section-title">
About Kamadenu Goushala
</h1>


<!-- Mission -->

<div class="card">

<div class="card-body">

<h2>
Our Mission
</h2>

<p>

Kamadenu Goushala is dedicated to rescuing, protecting, and caring for abandoned,
injured, and elderly cows. We provide shelter, food, and medical care to ensure
their safety and well-being.

</p>

</div>

</div>


<br>


<!-- Vision -->

<div class="card">

<div class="card-body">

<h2>
Our Vision
</h2>

<p>

Our vision is to create a safe and peaceful environment where every cow is
treated with respect and compassion, preserving traditional values and
supporting sustainable living.

</p>

</div>

</div>


<br>


<!-- Activities -->

<div class="card">

<div class="card-body">

<h2>
What We Do
</h2>

<ul>

<li>Rescue abandoned and injured cows</li>

<li>Provide daily feeding and medical care</li>

<li>Offer cow adoption and seva opportunities</li>

<li>Produce organic cow-based products</li>

<li>Promote gau seva awareness</li>

</ul>

</div>

</div>


<br>


<!-- Call to action -->

<div style="text-align:center; margin-top:40px;">

<h2>
Support Our Mission
</h2>

<p>
Your support helps us protect and care for sacred cows.
</p>

<br>

<a href="/donate" class="btn btn-primary">

Donate Now

</a>

</div>


</div>

</section>

</MainLayout>


