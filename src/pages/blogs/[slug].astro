---
import { getEntry, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

const { slug } = Astro.params;
const blog = slug ? await getEntry("blogs", slug) : undefined;

if (!blog) {
  Astro.response.status = 404;
}

const pageTitle = blog?.data.title ?? "Blog Not Found";
const rendered = blog ? await render(blog) : null;
const Content = rendered?.Content;
---

<MainLayout title={pageTitle}>
  {blog && Content ? (
  <section class="section">
    <div class="container">
      <h1>{blog.data.title}</h1>
      <p style="font-size:14px; color:#888; margin-top:8px;">
        {blog.data.author} | {blog.data.date.toLocaleDateString("en-IN", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        })}
      </p>

      <br />

      <img src={blog.data.cover_image} class="detail-image" alt={blog.data.title} />

      <br /><br />

      <Content />
    </div>
  </section>
  ) : (
  <section class="section">
    <div class="container" style="text-align:center;">
      <h1 class="section-title">Blog Not Found</h1>
      <p>The requested blog article does not exist.</p>
      <br />
      <a href="/blogs" class="btn btn-outline">Back to Blogs</a>
    </div>
  </section>
  )}
</MainLayout>
