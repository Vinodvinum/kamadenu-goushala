---
import MainLayout from "../../layouts/MainLayout.astro";
import BreedProfilePage from "../../components/BreedProfilePage.astro";

const galleryImages = [
  "/images/cows/amritamahal/1.jpg",
  "/images/cows/amritamahal/2.jpg",
  "/images/cows/amritamahal/3.jpg",
];
---

<MainLayout title="Amritamahal">
  <BreedProfilePage
    breedName="Amritamahal"
    heroImage="/images/cows/amritamahal/1.jpg"
    origin="A historic Karnataka breed developed for strength and endurance, especially in old military and agrarian contexts."
    physicalTraits="Tall, athletic build with firm limbs and distinctive horn shape suited to sustained work."
    milkQuality="Lower milk yield compared to dedicated dairy breeds, but valued for hardiness and maintenance efficiency."
    agriculturalValue="Excellent draught capability for field preparation and transport in semi-arid farming regions."
    galleryImages={galleryImages}
  />
</MainLayout>
