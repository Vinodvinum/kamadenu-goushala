---
import MainLayout from "../../layouts/MainLayout.astro";
import BreedProfilePage from "../../components/BreedProfilePage.astro";

const galleryImages = [
  "/images/cows/gir/1.jpg",
  "/images/cows/gir/2.jpg",
  "/images/cows/gir/3.jpg",
];
---

<MainLayout title="Gir">
  <BreedProfilePage
    breedName="Gir"
    heroImage="/images/cows/gir/1.jpg"
    origin="Originates from the Gir forest region of Gujarat and is one of India's best-known indigenous dairy breeds."
    physicalTraits="Convex forehead, long pendulous ears, and robust body structure with high heat tolerance."
    milkQuality="Widely appreciated for quality milk and suitability in traditional desi dairy systems."
    agriculturalValue="Supports mixed farming through steady milk contribution, manure generation, and adaptability to tropical conditions."
    galleryImages={galleryImages}
  />
</MainLayout>
