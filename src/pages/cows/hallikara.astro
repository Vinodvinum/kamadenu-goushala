---
import MainLayout from "../../layouts/MainLayout.astro";
import BreedProfilePage from "../../components/BreedProfilePage.astro";

const galleryImages = [
  "/images/cows/hallikara/1.jpg",
  "/images/cows/hallikara/2.jpg",
  "/images/cows/hallikara/3.jpg",
];
---

<MainLayout title="Hallikara">
  <BreedProfilePage
    breedName="Hallikara"
    heroImage="/images/cows/hallikara/1.jpg"
    origin="An indigenous breed of Karnataka associated with southern dry zones and known as a foundation of several regional cattle lines."
    physicalTraits="Medium framed with a muscular build, distinct horns, and strong legs suitable for long-distance movement."
    milkQuality="Primarily a draught-focused breed with moderate milk output and hardy constitution under local feeding conditions."
    agriculturalValue="Traditionally preferred for ploughing and cart work due to stamina, speed, and ability to work in warm climates."
    galleryImages={galleryImages}
  />
</MainLayout>
