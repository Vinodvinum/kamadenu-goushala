---
import MainLayout from "../../layouts/MainLayout.astro";
import { sanityFetch, urlFor } from "../../lib/sanityClient";
import { COW_BY_SLUG_QUERY } from "../../lib/queries";
import type { CowProfile } from "../../lib/types";

const { slug } = Astro.params;

let cow: CowProfile | null = null;
let error: string | null = null;

try {
  cow = await sanityFetch<CowProfile>({ query: COW_BY_SLUG_QUERY, params: { slug } });
} catch (e) {
  error = "Failed to load cow profile.";
  console.error("Cow profile error:", e);
}

if (!cow && !error) {
  return Astro.redirect('/cows');
}
---

<MainLayout title={cow?.breedName ?? 'Cow Profile'} description={cow?.description}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    {error && (
      <div class="bg-red-50 text-red-700 p-4 rounded-lg mb-6">{error}</div>
    )}
    {cow && (
      <>
        <header class="mb-8">
          {cow.isFeatured && (
            <span class="bg-yellow-100 text-yellow-800 text-sm px-3 py-1 rounded-full mb-4 inline-block">Featured Breed</span>
          )}
          <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mt-4 mb-4">{cow.breedName}</h1>
          <div class="flex flex-wrap gap-4 text-gray-600">
            {cow.origin && <span>Origin: {cow.origin}</span>}
            {cow.milkYield && <span>Milk Yield: {cow.milkYield}</span>}
          </div>
        </header>
        {cow.heroImage && (
          <div class="mb-8 rounded-xl overflow-hidden">
            <img src={urlFor(cow.heroImage).width(800).height(400).url()} alt={cow.breedName} class="w-full object-cover" />
          </div>
        )}
        {cow.description && (
          <div class="prose prose-lg max-w-none mb-8">
            <p class="text-gray-600 text-lg leading-relaxed">{cow.description}</p>
          </div>
        )}
        {cow.characteristics && cow.characteristics.length > 0 && (
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Characteristics</h2>
            <ul class="list-disc list-inside space-y-2">
              {cow.characteristics.map((c: string) => (
                <li class="text-gray-600">{c}</li>
              ))}
            </ul>
          </div>
        )}
        {cow.gallery && cow.gallery.length > 0 && (
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Gallery</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              {cow.gallery.map((img: any) => (
                <div class="rounded-lg overflow-hidden">
                  <img src={urlFor(img).width(400).height(300).url()} alt={cow!.breedName} class="w-full h-full object-cover" />
                </div>
              ))}
            </div>
          </div>
        )}
        <div class="mt-12">
          <a href="/cows" class="text-green-700 hover:text-green-900 font-medium">← Back to Our Cows</a>
        </div>
      </>
    )}
  </article>
</MainLayout>
