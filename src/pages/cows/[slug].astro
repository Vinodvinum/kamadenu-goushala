---
import MainLayout from "../../layouts/MainLayout.astro";
import { getAllCows } from "../../lib/content.js";

export async function getStaticPaths() {
  const cows = await getAllCows();
  return cows.map((cow) => ({
    params: { slug: cow.slug },
    props: { cow },
  }));
}

const { cow } = Astro.props;

const feedLink = `https://wa.me/919448604890?text=${encodeURIComponent(
`🙏 Kamadenu Goushala

I would like to support daily feeding seva for:
🐄 ${cow.name}

Please guide me with the process.`
)}`;

const adoptLink = `https://wa.me/919448604890?text=${encodeURIComponent(
`🙏 Kamadenu Goushala

I would like to adopt this cow:
🐄 ${cow.name}

Please share monthly adoption details.`
)}`;
---

<MainLayout title={cow.name}>

<section class="section">

<div class="container">

<div class="detail-grid">

<div>

<img
src={cow.image}
class="detail-image"
alt={cow.name}>

</div>


<div>

<h1>
{cow.name}
</h1>

<p>
Age: {cow.age}
</p>

<p>
Breed: {cow.breed}
</p>

<p>
Status: {cow.status}
</p>

<br>

<p>
{cow.story}
</p>

<br>

<div class="cow-card-actions">
<a
href={feedLink}
target="_blank"
class="btn btn-primary">
Feed a Cow
</a>

<a
href={adoptLink}
target="_blank"
class="btn btn-outline">
Adopt this Cow
</a>
</div>

</div>


</div>

</div>

</section>

</MainLayout>
