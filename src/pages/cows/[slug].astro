---
import MainLayout from "../../layouts/MainLayout.astro";
import { sanityFetch, urlFor } from "../../lib/sanityClient";
import { COW_BY_SLUG_QUERY, ALL_COWS_QUERY } from "../../lib/queries";
import type { CowProfile } from "../../lib/types";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const cows = await sanityFetch<CowProfile[]>({ query: ALL_COWS_QUERY });
  return cows.map((cow) => ({
    params: { slug: cow.slug.current },
  }));
}

const { slug } = Astro.params;
let breed: CowProfile | null = null;
let error: string | null = null;

try {
  breed = await sanityFetch<CowProfile>({ query: COW_BY_SLUG_QUERY, params: { slug } });
} catch (e) {
  error = "Failed to load breed details.";
  console.error("Cow detail page error:", e);
}

if (!breed && !error) {
  return Astro.redirect("/404");
}

const breedName = breed?.breedName ?? "Breed Not Found";

const feedLink = `https://wa.me/919448604890?text=${encodeURIComponent(
  `Hello Kamadenu Goushala,

I would like to support daily feeding seva for ${breedName} cows.`
)}`;

const adoptLink = `https://wa.me/919448604890?text=${encodeURIComponent(
  `Hello Kamadenu Goushala,

I would like to adopt and support ${breedName} cows.`
)}`;
---

<MainLayout title={breedName}>
  {error && (
    <div class="error-banner" role="alert">
      <p>{error}</p>
    </div>
  )}

  {breed ? (
    <>
      <section class="section breed-header-section">
        <div class="container">
          <h1 class="breed-title">{breed.breedName}</h1>

          {breed.heroImage && (
            <img
              src={urlFor(breed.heroImage).width(800).height(500).url()}
              alt={breed.breedName}
              class="breed-hero-image"
              loading="eager"
            />
          )}

          <div class="breed-info">
            <div class="breed-description">
              <h2>About {breed.breedName}</h2>
              <p>{breed.description}</p>
            </div>

            <div class="breed-characteristics">
              <h2>Characteristics</h2>

              {breed.origin && (
                <div class="characteristic-item">
                  <h3>Origin</h3>
                  <p>{breed.origin}</p>
                </div>
              )}

              {breed.milkYield && (
                <div class="characteristic-item">
                  <h3>Milk Yield</h3>
                  <p>{breed.milkYield}</p>
                </div>
              )}

              {breed.characteristics && (
                <div class="characteristic-item">
                  <h3>Physical Traits</h3>
                  <PortableText value={breed.characteristics} />
                </div>
              )}
            </div>
          </div>

          <div class="breed-actions">
            <a href={feedLink} class="btn btn-primary" target="_blank" rel="noopener noreferrer">Feed a Cow</a>
            <a href={adoptLink} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">Adopt a Cow</a>
          </div>
        </div>
      </section>

      {breed.gallery && breed.gallery.length > 0 && (
        <section class="section">
          <div class="container">
            <h2 class="section-title">Cow Gallery</h2>
            <div class="gallery-grid">
              {breed.gallery.map((image, index) => (
                <img
                  src={urlFor(image).width(400).height(300).url()}
                  alt={`${breed.breedName} ${index + 1}`}
                  class="gallery-item"
                  loading="lazy"
                />
              ))}
            </div>
          </div>
        </section>
      )}
    </>
  ) : (
    <section class="section">
      <div class="container">
        <h1>Breed Not Found</h1>
        <p>The requested breed page does not exist.</p>
        <br />
        <a href="/cows" class="btn btn-primary">Back to Breeds</a>
      </div>
    </section>
  )}
</MainLayout>
