---
import MainLayout from "../../layouts/MainLayout.astro";
import { sanityFetch, urlFor } from "../../lib/sanityClient";
import { COW_BY_SLUG_QUERY } from "../../lib/queries";
import type { CowProfile } from "../../lib/types";

const { slug } = Astro.params;

let cow: CowProfile | null = null;
let error: string | null = null;

try {
  cow = await sanityFetch<CowProfile>({ query: COW_BY_SLUG_QUERY, params: { slug } });
} catch (e) {
  error = "Failed to load cow profile.";
  console.error("Cow profile error:", e);
}

if (!cow && !error) {
  return Astro.redirect('/cows');
}
---

<MainLayout title={cow?.name ?? 'Cow Profile'} description={cow?.description}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    {error && (
      <div class="bg-red-50 text-red-700 p-4 rounded-lg mb-6">{error}</div>
    )}
    {cow && (
      <>
        <header class="mb-8">
          {cow.adoptionStatus && (
            <span class={`text-sm px-3 py-1 rounded-full mb-4 inline-block ${
              cow.adoptionStatus === 'adopted' ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800'
            }`}>
              {cow.adoptionStatus === 'adopted' ? 'Adopted' : 'Available for Adoption'}
            </span>
          )}
          <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mt-4 mb-4">{cow.name}</h1>
          <div class="flex flex-wrap gap-6 text-gray-600">
            {cow.breed && <span class="font-medium">Breed: {cow.breed}</span>}
            {cow.age && <span>Age: {cow.age} years</span>}
            {cow.weight && <span>Weight: {cow.weight} kg</span>}
            {cow.dailyMilkYield && <span>Daily Milk: {cow.dailyMilkYield} litres</span>}
          </div>
        </header>
        {cow.image && (
          <div class="mb-8 rounded-xl overflow-hidden">
            <img src={urlFor(cow.image).width(800).height(500).url()} alt={cow.name} class="w-full object-cover" />
          </div>
        )}
        {cow.description && (
          <div class="prose prose-lg max-w-none">
            <p class="text-gray-600 text-lg leading-relaxed">{cow.description}</p>
          </div>
        )}
        {cow.adoptionStatus === 'available' && (
          <div class="mt-8 bg-green-50 rounded-xl p-6">
            <h3 class="text-xl font-semibold text-green-800 mb-2">Adopt {cow.name}</h3>
            <p class="text-green-700 mb-4">Help support {cow.name}'s care. Your adoption donation covers daily feeding, medical care, and shelter.</p>
            <a href="/donate" class="bg-green-700 text-white px-6 py-3 rounded-lg hover:bg-green-800 transition-colors inline-block">Donate for Adoption</a>
          </div>
        )}
        <div class="mt-12">
          <a href="/cows" class="text-green-700 hover:text-green-900 font-medium">&larr; Back to Our Cows</a>
        </div>
      </>
    )}
  </article>
</MainLayout>
