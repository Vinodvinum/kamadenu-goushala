---
import MainLayout from "../../layouts/MainLayout.astro";
import BreedProfilePage from "../../components/BreedProfilePage.astro";

const galleryImages = [
  "/images/cows/tharparkar/1.jpg",
  "/images/cows/tharparkar/2.jpg",
  "/images/cows/tharparkar/3.jpg",
];
---

<MainLayout title="Tharparkar">
  <BreedProfilePage
    breedName="Tharparkar"
    heroImage="/images/cows/tharparkar/1.jpg"
    origin="Native to the Thar desert belt, this breed is adapted to dry climates and limited-fodder environments."
    physicalTraits="Medium to large frame with light-colored coat, strong hooves, and high heat resilience."
    milkQuality="Considered a dual-purpose breed with dependable milk output under challenging climatic conditions."
    agriculturalValue="Useful in drought-prone agriculture due to resilience, work capacity, and lower maintenance demand."
    galleryImages={galleryImages}
  />
</MainLayout>
