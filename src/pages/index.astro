---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import DonateSection from "../components/DonateSection.astro";
import { sanityFetch, urlFor } from "../lib/sanityClient";
import { FEATURED_EVENTS_QUERY, FEATURED_COWS_QUERY } from "../lib/queries";
import type { Event, CowProfile } from "../lib/types";

let featuredEvents: Event[] = [];
let featuredBreeds: CowProfile[] = [];
let error: string | null = null;

try {
  [featuredEvents, featuredBreeds] = await Promise.all([
    sanityFetch<Event[]>({ query: FEATURED_EVENTS_QUERY }),
    sanityFetch<CowProfile[]>({ query: FEATURED_COWS_QUERY }),
  ]);
} catch (e) {
  error = "Failed to load some content. Please try again later.";
  console.error("Homepage error:", e);
}

const activities = [
  {
    title: "Events",
    description: "Join upcoming temple programs, gau seva drives, and community gatherings.",
    href: "/events",
    image: "/images/events/1.jpg",
  },
  {
    title: "News",
    description: "Read updates about rescue work, goshala milestones, and field outreach.",
    href: "/news",
    image: "/images/activities/1.jpg",
  },
  {
    title: "Gallery",
    description: "See moments from daily care, cow shelter life, and devotional activities.",
    href: "/gallery",
    image: "/images/gallery/1.jpg",
  },
];

const highlights = [
  {
    title: "Havana",
    description: "Learn about sacred havana offerings and spiritual activities at the goshala.",
    href: "/havana",
    image: "/images/about/goushala.jpg",
  },
  {
    title: "Indigenous Breeds",
    description: "Explore native cow breeds and their role in dharmic and agricultural life.",
    href: "/cows",
    image: "/images/cows/gir/1.jpg",
  },
  {
    title: "Astrology",
    description: "Explore Vedic astrology based guidance connected to seva and tradition.",
    href: "/astrology",
    image: "/images/hero/hero.jpg",
  },
];
---

<MainLayout title="Kamadenu Goushala - Sacred Cow Sanctuary">
  <Hero />
  <Stats />

  {error && (
    <div class="error-banner" role="alert">
      <p>{error}</p>
    </div>
  )}

  {featuredEvents.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Featured Events</h2>
        <div class="events-grid">
          {featuredEvents.map((event) => (
            <div class="event-card">
              {event.coverImage ? (
                <img
                  src={urlFor(event.coverImage).width(400).height(250).url()}
                  alt={event.title}
                  class="event-card__image"
                  loading="lazy"
                />
              ) : (
                <div class="event-card__image event-card__image--placeholder"></div>
              )}
              <div class="event-card__content">
                <h3 class="event-card__title">{event.title}</h3>
                <p class="event-card__location">{event.location}</p>
                <p class="event-card__date">
                  {new Date(event.date).toLocaleDateString("en-IN", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric",
                  })}
                </p>
                <a href={`/events/${event.slug.current}`} class="btn btn-primary">Know more</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <h2 class="section-title">Activities</h2>
      <div class="activities-grid">
        {activities.map((item) => (
          <div class="activity-card">
            <img src={item.image} alt={item.title} class="activity-card__image" loading="lazy" />
            <div class="activity-card__content">
              <h3 class="activity-card__title">{item.title}</h3>
              <p class="activity-card__description">{item.description}</p>
              <a href={item.href} class="btn btn-secondary">Know more</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Highlights</h2>
      <div class="highlights-grid">
        {highlights.map((item) => (
          <div class="highlight-card">
            <img src={item.image} alt={item.title} class="highlight-card__image" loading="lazy" />
            <div class="highlight-card__content">
              <h3 class="highlight-card__title">{item.title}</h3>
              <p class="highlight-card__description">{item.description}</p>
              <a href={item.href} class="btn btn-secondary">Know more</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {featuredBreeds.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Indigenous Breeds Preview</h2>
        <div class="cows-grid">
          {featuredBreeds.map((breed) => (
            <a href={`/cows/${breed.slug.current}`} class="cow-card">
              {breed.heroImage ? (
                <img
                  src={urlFor(breed.heroImage).width(400).height(300).url()}
                  alt={breed.breedName}
                  class="cow-card__image"
                  loading="lazy"
                />
              ) : (
                <div class="cow-card__image cow-card__image--placeholder"></div>
              )}
              <h3 class="cow-card__name">{breed.breedName}</h3>
            </a>
          ))}
        </div>
        <a href="/cows" class="btn btn-secondary">Explore Breeds</a>
      </div>
    </section>
  )}

  <DonateSection />
</MainLayout>
