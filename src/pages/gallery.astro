---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

const gallerySets = await getCollection("gallery");

function normalizeImage(item: string | { image: string }): string {
  return typeof item === "string" ? item : item.image;
}
---

<MainLayout title="Gallery">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Gallery</h1>

      <div class="grid">
        {gallerySets.map((set) => (
          <article class="card">
            <div class="card-body">
              <h2 class="card-title">{set.data.title}</h2>
            </div>

            <div class="grid" style="padding: 0 20px 20px;">
              {set.data.images.map((image, index) => (
                <img
                  src={normalizeImage(image)}
                  alt={`${set.data.title} ${index + 1}`}
                  class="breed-gallery-image"
                />
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
