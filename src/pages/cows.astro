---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

const breeds = await getCollection("cows");
---

<MainLayout title="Indigenous Breeds">

<section class="section">

<div class="container">

<h1 class="section-title">
Indigenous Cow Breeds
</h1>

<p class="section-intro">
Explore the sacred native breeds protected by Kamadenu Goushala.
</p>

<div class="breed-sections">

{
breeds.map((breed) => (

<article class="card breed-section-card">

<img src={breed.data.hero_image} alt={breed.data.breed_name}>

<div class="card-body">

<h2 class="card-title">
{breed.data.breed_name}
</h2>

<p>
<strong>Origin:</strong> {breed.data.origin}
</p>

<p>
<strong>Milk Quality:</strong> {breed.data.milk_quality}
</p>

<br>

<a href={`/cows/${breed.slug}`} class="btn btn-outline">Know more</a>

</div>

</article>

))
}

</div>


</div>

</section>

</MainLayout>
