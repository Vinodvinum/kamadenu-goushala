---
import { getEntry } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { markdownToHtml } from "../../lib/markdown";

const { slug } = Astro.params;
const event = slug ? await getEntry("events", slug) : undefined;

if (!event) {
  Astro.response.status = 404;
}

const pageTitle = event?.data.title ?? "Event Not Found";
const descriptionHtml = event ? markdownToHtml(event.data.description) : "";
---

<MainLayout title={pageTitle}>
  {event ? (
  <section class="section">
    <div class="container">
      <h1>{event.data.title}</h1>

      <p style="font-size:14px; color:#777; margin-top:8px;">
        {event.data.date.toLocaleDateString("en-IN", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        })}
        | {event.data.location}
      </p>

      <br />

      <img src={event.data.cover_image} alt={event.data.title} class="detail-image" />

      <br /><br />

      <div set:html={descriptionHtml}></div>
    </div>
  </section>
  ) : (
  <section class="section">
    <div class="container" style="text-align:center;">
      <h1 class="section-title">Event Not Found</h1>
      <p>The requested event page does not exist.</p>
      <br />
      <a href="/events" class="btn btn-outline">Back to Events</a>
    </div>
  </section>
  )}
</MainLayout>
