---
import MainLayout from "../../layouts/MainLayout.astro";
import { sanityFetch, urlFor } from "../../lib/sanityClient";
import { POST_BY_SLUG_QUERY } from "../../lib/queries";
import type { BlogPost } from "../../lib/types";
import { PortableText } from "astro-portabletext";

const { slug } = Astro.params;

let post: BlogPost | null = null;
let error: string | null = null;

try {
  post = await sanityFetch<BlogPost>({ query: POST_BY_SLUG_QUERY, params: { slug } });
} catch (e) {
  error = "Failed to load blog post.";
  console.error("Blog post error:", e);
}

if (!post && !error) {
  return Astro.redirect('/blog');
}
---

<MainLayout title={post?.title ?? 'Blog Post'} description={post?.excerpt}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    {error && (
      <div class="bg-red-50 text-red-700 p-4 rounded-lg mb-6">{error}</div>
    )}
    {post && (
      <>
        <header class="mb-8">
          {post.category && (
            <span class="bg-green-100 text-green-800 text-sm px-3 py-1 rounded-full">{post.category}</span>
          )}
          <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mt-4 mb-4">{post.title}</h1>
          <div class="flex items-center gap-4 text-gray-500 text-sm">
            {post.author && <span>By {post.author}</span>}
            {post.publishedAt && (
              <span>{new Date(post.publishedAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            )}
          </div>
        </header>
        {post.coverImage && (
          <div class="mb-8 rounded-xl overflow-hidden">
            <img src={urlFor(post.coverImage).width(800).height(400).url()} alt={post.title} class="w-full object-cover" />
          </div>
        )}
        <div class="prose prose-lg max-w-none">
          {post.body && post.body.length > 0 ? (
            <PortableText value={post.body} />
          ) : (
            post.excerpt && <p>{post.excerpt}</p>
          )}
        </div>
        <div class="mt-12">
          <a href="/blog" class="text-green-700 hover:text-green-900 font-medium">&larr; Back to Blog</a>
        </div>
      </>
    )}
  </article>
</MainLayout>
