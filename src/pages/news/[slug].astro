---
import MainLayout from "../../layouts/MainLayout.astro";
import { sanityFetch, urlFor } from "../../lib/sanityClient";
import { POST_BY_SLUG_QUERY } from "../../lib/queries";
import type { BlogPost } from "../../lib/types";

const { slug } = Astro.params;

let newsItem: BlogPost | null = null;
let error: string | null = null;

try {
  newsItem = await sanityFetch<BlogPost>({ query: POST_BY_SLUG_QUERY, params: { slug } });
} catch (e) {
  error = "Failed to load news article.";
  console.error("News error:", e);
}

if (!newsItem && !error) {
  return Astro.redirect('/news');
}
---

<MainLayout title={newsItem?.title ?? 'News'} description={newsItem?.excerpt}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    {error && (
      <div class="bg-red-50 text-red-700 p-4 rounded-lg mb-6">{error}</div>
    )}
    {newsItem && (
      <>
        <header class="mb-8">
          {newsItem.category && (
            <span class="bg-blue-100 text-blue-800 text-sm px-3 py-1 rounded-full">{newsItem.category}</span>
          )}
          <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mt-4 mb-4">{newsItem.title}</h1>
          <div class="flex items-center gap-4 text-gray-500 text-sm">
            {newsItem.author && <span>By {newsItem.author}</span>}
            {newsItem.date && (
              <span>{new Date(newsItem.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            )}
          </div>
        </header>
        {newsItem.coverImage && (
          <div class="mb-8 rounded-xl overflow-hidden">
            <img src={urlFor(newsItem.coverImage).width(800).height(400).url()} alt={newsItem.title} class="w-full object-cover" />
          </div>
        )}
        {newsItem.excerpt && (
          <div class="prose prose-lg max-w-none">
            <p class="text-gray-600 text-lg leading-relaxed">{newsItem.excerpt}</p>
          </div>
        )}
        <div class="mt-12">
          <a href="/news" class="text-green-700 hover:text-green-900 font-medium">← Back to News</a>
        </div>
      </>
    )}
  </article>
</MainLayout>
