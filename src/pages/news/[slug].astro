---
import { getEntry, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

const { slug } = Astro.params;
const item = slug ? await getEntry("news", slug) : undefined;

if (!item) {
  Astro.response.status = 404;
}

const pageTitle = item?.data.title ?? "News Not Found";
const rendered = item ? await render(item) : null;
const Content = rendered?.Content;
---

<MainLayout title={pageTitle}>
  {item && Content ? (
  <section class="section">
    <div class="container">
      <h1>{item.data.title}</h1>
      <p style="font-size:14px; color:#777; margin-top:8px;">
        {item.data.date.toLocaleDateString("en-IN", {
          day: "2-digit",
          month: "long",
          year: "numeric",
        })}
      </p>

      <br />

      <img src={item.data.cover_image} alt={item.data.title} class="detail-image" />

      <br /><br />

      <Content />
    </div>
  </section>
  ) : (
  <section class="section">
    <div class="container" style="text-align:center;">
      <h1 class="section-title">News Not Found</h1>
      <p>The requested news article does not exist.</p>
      <br />
      <a href="/news" class="btn btn-outline">Back to News</a>
    </div>
  </section>
  )}
</MainLayout>
