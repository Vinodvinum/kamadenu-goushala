---
import MainLayout from "../layouts/MainLayout.astro";
import { sanityFetch, urlFor } from "../lib/sanityClient";
import { ALL_EVENTS_QUERY } from "../lib/queries";
import type { Event } from "../lib/types";

let events: Event[] = [];
let error: string | null = null;

try {
  events = await sanityFetch<Event[]>({ query: ALL_EVENTS_QUERY });
} catch (e) {
  error = "Failed to load events. Please try again later.";
  console.error("Events page error:", e);
}

const upcomingEvents = events.filter(
  (e) => new Date(e.date) >= new Date()
).sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEvents = events.filter(
  (e) => new Date(e.date) < new Date()
).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<MainLayout title="Events">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Events</h1>
      <p class="section-subtitle">Join us in our upcoming events and programs at Kamadenu Goushala.</p>

      {error && (
        <div class="error-banner" role="alert">
          <p>{error}</p>
        </div>
      )}

      {!error && events.length === 0 && (
        <div class="empty-state">
          <p>No events found. Check back soon!</p>
        </div>
      )}

      {upcomingEvents.length > 0 && (
        <div class="events-section">
          <h2 class="subsection-title">Upcoming Events</h2>
          <div class="events-grid">
            {upcomingEvents.map((event) => (
              <article class="event-card">
                {event.coverImage ? (
                  <img
                    src={urlFor(event.coverImage).width(600).height(400).url()}
                    alt={event.title}
                    class="event-card__image"
                    loading="lazy"
                  />
                ) : (
                  <div class="event-card__image event-card__image--placeholder"></div>
                )}
                <div class="event-card__body">
                  <h3 class="event-card__title">{event.title}</h3>
                  {event.location && <p class="event-card__location">{event.location}</p>}
                  <p class="event-card__date">
                    {new Date(event.date).toLocaleDateString("en-IN", {
                      day: "2-digit",
                      month: "short",
                      year: "numeric",
                    })}
                  </p>
                  {event.description && <p class="event-card__desc">{event.description}</p>}
                  <a href={`/events/${event.slug.current}`} class="btn btn-primary">Know more</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}

      {pastEvents.length > 0 && (
        <div class="events-section">
          <h2 class="subsection-title">Past Events</h2>
          <div class="events-grid">
            {pastEvents.map((event) => (
              <article class="event-card event-card--past">
                {event.coverImage ? (
                  <img
                    src={urlFor(event.coverImage).width(600).height(400).url()}
                    alt={event.title}
                    class="event-card__image"
                    loading="lazy"
                  />
                ) : (
                  <div class="event-card__image event-card__image--placeholder"></div>
                )}
                <div class="event-card__body">
                  <h3 class="event-card__title">{event.title}</h3>
                  {event.location && <p class="event-card__location">{event.location}</p>}
                  <p class="event-card__date">
                    {new Date(event.date).toLocaleDateString("en-IN", {
                      day: "2-digit",
                      month: "short",
                      year: "numeric",
                    })}
                  </p>
                  <a href={`/events/${event.slug.current}`} class="btn btn-secondary">View details</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</MainLayout>
