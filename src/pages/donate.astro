---
import MainLayout from "../layouts/MainLayout.astro";

const feedOneCowLink = `https://wa.me/919448604890?text=${encodeURIComponent(
`🙏 Kamadenu Goushala

I would like to donate for Feed One Cow seva (₹51).
Please guide me with payment details.`
)}`;

const feedTenCowsLink = `https://wa.me/919448604890?text=${encodeURIComponent(
`🙏 Kamadenu Goushala

I would like to donate for Feed 10 Cows seva (₹501).
Please guide me with payment details.`
)}`;

const fullDaySevaLink = `https://wa.me/919448604890?text=${encodeURIComponent(
`🙏 Kamadenu Goushala

I would like to donate for Full Day Feeding Seva (₹2001).
Please guide me with payment details.`
)}`;

const customDonationLink = `https://wa.me/919448604890?text=${encodeURIComponent(
`🙏 Kamadenu Goushala

I would like to make a custom donation for Gau Seva.
Please guide me with payment details.`
)}`;
---

<MainLayout title="Donate">

<section class="section">

<div class="container">

<h1 class="section-title">
Support Gau Seva
</h1>

<p style="text-align:center; max-width:700px; margin:auto; margin-bottom:40px;">

Your donation helps provide food, shelter, and medical care for rescued cows.
Every contribution supports our sacred mission.

</p>


<div class="grid">

<!-- Feed one cow -->

<div class="card">

<div class="card-body">

<h3 class="card-title">
Feed One Cow
</h3>

<p>
Provide food for one cow for a day.
</p>

<h3 style="color:#e67e22;">
₹51
</h3>

<br>

<a href={feedOneCowLink}
target="_blank"
class="btn btn-primary">

Donate Now

</a>

</div>

</div>


<!-- Feed multiple cows -->

<div class="card">

<div class="card-body">

<h3 class="card-title">
Feed 10 Cows
</h3>

<p>
Support feeding seva for multiple cows.
</p>

<h3 style="color:#e67e22;">
₹501
</h3>

<br>

<a href={feedTenCowsLink}
target="_blank"
class="btn btn-primary">

Donate Now

</a>

</div>

</div>


<!-- Full day feeding -->

<div class="card">

<div class="card-body">

<h3 class="card-title">
Full Day Feeding Seva
</h3>

<p>
Sponsor feeding for all cows for one day.
</p>

<h3 style="color:#e67e22;">
₹2001
</h3>

<br>

<a href={fullDaySevaLink}
target="_blank"
class="btn btn-primary">

Donate Now

</a>

</div>

</div>


</div>


<!-- Custom donation -->

<br><br>

<div style="text-align:center;">

<h2>
Custom Donation
</h2>

<p>
Donate any amount and we will guide you on WhatsApp.
</p>

<br>

<a
href={customDonationLink}
target="_blank"
class="btn btn-outline">

Contact for Donation

</a>

</div>


</div>

</section>

</MainLayout>
