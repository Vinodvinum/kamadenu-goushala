---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "Kamadenu Goushala" } = Astro.props;
const donateWhatsAppLink = `https://wa.me/919448604890?text=${encodeURIComponent(
`🙏 Kamadenu Goushala

I would like to donate for Gau Seva.
Please guide me with payment details.`
)}`;
---

<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>{title}</title>

</head>

<script>

const gauPopup = document.getElementById("gauPopup");

function showGauPopup(){

if(!gauPopup) return;

gauPopup.classList.add("show");

setTimeout(()=>{
gauPopup.classList.remove("show");
},4000);

}

setTimeout(showGauPopup,3000);

setInterval(showGauPopup,10000);



const gauAlert = document.getElementById("gauAlert");

function showGauAlert(){

if(!gauAlert) return;

gauAlert.classList.add("show");

setTimeout(()=>{
gauAlert.classList.remove("show");
},10000);

}

setTimeout(showGauAlert,8000);

setInterval(showGauAlert,60000);


</script>

<body> 

<Header />



<main>
<slot />

</main>

